# ─── Server ─────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Mock mode ──────────────────────────────────────────────────────────────
# Set USE_MOCK=true to serve deterministic fixture data instead of calling
# the flight data provider. Useful for offline dev, UI work, or demos.
# Optional tuning (defaults in mockFlightService.js):
#   MOCK_DELAY_MS=60                  per-call simulated latency
#   MOCK_VERIFY_SUCCESS_RATE=0.95     fraction of pricing calls that succeed
#   MOCK_VERIFY_CHANGE_RATE=0.15      fraction with ±3-8% price change
USE_MOCK=false

# ─── Flight data provider ───────────────────────────────────────────────────
# "travelpayouts" (default): Aviasales Data API — precios cacheados 48h
# gratuitos + deep links de afiliado. USE_MOCK=true ignora esta variable.
# FLIGHT_PROVIDER=travelpayouts

# ─── Travelpayouts / Aviasales Data API ─────────────────────────────────────
# Token en https://app.travelpayouts.com/profile/api-token (alta self-service).
# Requerido en producción (USE_MOCK=false).
TRAVELPAYOUTS_TOKEN=
# Marker de afiliado (Partner ID, abajo a la izquierda en app.travelpayouts.com).
# Se añade a cada deep link de Aviasales; sin él las reservas NO se atribuyen
# y la comisión se pierde. Admite SubID con punto: "738121.app".
# TRAVELPAYOUTS_MARKER=
# Market de la caché. Vacío = auto (deducido del origen de cada búsqueda,
# recomendado para multi-origen). Fijar p.ej. "es" solo si el sondeo de
# densidad lo justifica: node scripts/probe-travelpayouts.js
# TRAVELPAYOUTS_MARKET=
# Tuning opcional (defaults en travelpayoutsService.js):
#   TP_RATE_MIN_INTERVAL_MS=110     límite API: 600 req/min
#   TP_MAX_CONCURRENCY=5
#   TP_MAX_RETRIES=3
#   TP_BASE_BACKOFF_MS=500
#   TP_SEARCH_CACHE_TTL_MS=3600000  caché local (60 min)
#   TP_DATE_FLEX_DAYS=2             fallback a fechas vecinas (±N días) cuando
#                                   la fecha exacta no tiene precio en caché;
#                                   el resultado se etiqueta con su fecha real.
#                                   0 = desactivado

# ─── Search tuning ──────────────────────────────────────────────────────────
# Destinations returned per search. 6 (default) is enough to decide.
# SEARCH_TARGET_RESULTS=6

# ─── CORS / frontend (production) ───────────────────────────────────────────
# Comma-separated list of allowed origins. Leave empty in dev to allow all.
# ALLOWED_ORIGINS=https://flyndme2.vercel.app,https://www.flyndme.com
# Used by /api/share/:id/og for social preview redirects
# FRONTEND_URL=https://flyndme2.vercel.app

# ─── Production checklist ──────────────────────────────────────────────────
# When NODE_ENV=production the backend runs validateConfig() at startup and
# refuses to boot if TRAVELPAYOUTS_TOKEN is missing (set USE_MOCK=true to
# skip that requirement). It also warns when TRAVELPAYOUTS_MARKER,
# ALLOWED_ORIGINS or FRONTEND_URL are unset. Required for prod:
#   NODE_ENV=production
#   TRAVELPAYOUTS_TOKEN=...   (proveedor primario)
#   TRAVELPAYOUTS_MARKER=...  (monetización por afiliados)
#   ALLOWED_ORIGINS=https://your-domain
#   FRONTEND_URL=https://your-domain
# Escape hatch (emergency only): ALLOW_INSECURE_PROD=true forces start.
