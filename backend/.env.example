# ─── Server ─────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Mock mode ──────────────────────────────────────────────────────────────
# Set USE_MOCK=true to serve deterministic fixture data instead of calling
# Amadeus. Useful for offline dev, UI work, or burning no quota during demos.
# Optional tuning (defaults in mockAmadeusService.js):
#   MOCK_DELAY_MS=60                  per-call simulated latency
#   MOCK_VERIFY_SUCCESS_RATE=0.95     fraction of pricing calls that succeed
#   MOCK_VERIFY_CHANGE_RATE=0.15      fraction with ±3-8% price change
USE_MOCK=false

# ─── Flight data provider ───────────────────────────────────────────────────
# "amadeus" (default, sunset 17-jul-2026) | "travelpayouts" (Aviasales Data
# API: precios cacheados 48h gratuitos + deep links de afiliado).
# USE_MOCK=true ignora esta variable.
# FLIGHT_PROVIDER=travelpayouts

# ─── Travelpayouts / Aviasales Data API ─────────────────────────────────────
# Token en https://app.travelpayouts.com/profile/api-token (alta self-service).
# Requerido cuando FLIGHT_PROVIDER=travelpayouts.
TRAVELPAYOUTS_TOKEN=
# Market de la caché. Vacío = auto (deducido del origen de cada búsqueda,
# recomendado para multi-origen). Fijar p.ej. "es" solo si el sondeo de
# densidad lo justifica: node scripts/probe-travelpayouts.js
# TRAVELPAYOUTS_MARKET=
# Tuning opcional (defaults en travelpayoutsService.js):
#   TP_RATE_MIN_INTERVAL_MS=110     límite API: 600 req/min
#   TP_MAX_CONCURRENCY=5
#   TP_MAX_RETRIES=3
#   TP_BASE_BACKOFF_MS=500
#   TP_SEARCH_CACHE_TTL_MS=3600000  caché local (60 min)

# ─── Amadeus API (required when FLIGHT_PROVIDER=amadeus and USE_MOCK=false) ─
# Get credentials at https://developers.amadeus.com
# AMADEUS_ENV: "test" (sandbox, limited inventory) or "production" (real data)
AMADEUS_API_KEY=
AMADEUS_API_SECRET=
AMADEUS_ENV=test

# ─── Amadeus tuning (optional — sensible defaults in code) ─────────────────
# AMADEUS_RATE_MIN_INTERVAL_MS=100
# AMADEUS_MAX_CONCURRENCY=3
# AMADEUS_MAX_RETRIES=3
# AMADEUS_BASE_BACKOFF_MS=600
# AMADEUS_SEARCH_CACHE_TTL_MS=3600000   # search cache TTL (default 60 min)

# ─── Monthly budget guard ───────────────────────────────────────────────────
# Hard cap on real Amadeus calls (search + verification) per calendar month.
# Protects the free production quota (2,000 calls/month for Flight Offers
# Search) so the MVP never generates a bill. Default 1800 (margin for retries
# and process restarts — the counter lives in memory). Set 0 to disable.
# Check usage anytime: GET /api/flights/budget
# AMADEUS_MONTHLY_BUDGET=1800

# ─── Search tuning ──────────────────────────────────────────────────────────
# Destinations returned per search. 6 (default) is enough to decide and uses
# ~33% less quota than 9.
# SEARCH_TARGET_RESULTS=6

# ─── CORS / frontend (production) ───────────────────────────────────────────
# Comma-separated list of allowed origins. Leave empty in dev to allow all.
# ALLOWED_ORIGINS=https://flyndme.vercel.app,https://www.flyndme.com
# Used by /api/share/:id/og for social preview redirects
# FRONTEND_URL=https://flyndme.vercel.app

# ─── Production checklist ──────────────────────────────────────────────────
# When NODE_ENV=production the backend runs validateConfig() at startup and
# refuses to boot if AMADEUS_API_KEY/SECRET are missing (set USE_MOCK=true to
# skip that requirement). It also warns when ALLOWED_ORIGINS or FRONTEND_URL
# are unset. Required for prod:
#   NODE_ENV=production
#   FLIGHT_PROVIDER=travelpayouts + TRAVELPAYOUTS_TOKEN   (proveedor primario)
#     — o, hasta el 17-jul-2026: AMADEUS_API_KEY/SECRET + AMADEUS_ENV=production
#   ALLOWED_ORIGINS=https://your-domain
#   FRONTEND_URL=https://your-domain
# Escape hatch (emergency only): ALLOW_INSECURE_PROD=true forces start.

