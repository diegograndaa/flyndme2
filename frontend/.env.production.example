# Vite production build env. Copy to .env.production and fill in.
#
# Set the backend URL for the deployed build. If left unset the bundle falls
# back to https://flyndme-backend.onrender.com (hardcoded in App.jsx) — fine
# for the current Render deploy but you'll want to override it once you move.
VITE_API_BASE_URL=https://flyndme-backend.onrender.com

# Optional: Skyscanner affiliate ID, appended to outbound booking links.
# Leave unset to skip affiliate tagging.
# VITE_SKYSCANNER_AFFILIATE_ID=
